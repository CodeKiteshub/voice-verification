# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/voice_verification

# ─── Telephony ───────────────────────────────────────────────────────────────
ACTIVE_PROVIDER=exotel

# Exotel
EXOTEL_ACCOUNT_SID=your_account_sid
EXOTEL_API_KEY=your_api_key
EXOTEL_API_TOKEN=your_api_token
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=08XXXXXXXXXX

# Vobiz
VOBIZ_API_KEY=your_vobiz_api_key
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token
VOBIZ_CALLER_ID=+918XXXXXXXXX

# ─── STT ─────────────────────────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key
STT_ENABLED=true

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Public URL that Exotel/Vobiz can POST to.
# For local dev: use ngrok → "npx ngrok http 3000"
# No trailing slash.
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io
NEXT_PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io
